# CocoaPods / SPM
Pods/
.build/

# Secrets / config (never commit API keys or GoogleService-Info.plist)
GoogleService-Info.plist
*.xcconfig
Secrets.swift
.env

# Fastlane (if added later)
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Release build artifacts (scripts/build_and_notarize_mac.sh output)
build/
*.dmg
*.xcarchive

# Firebase service account keys — never commit these
*firebase*key*.json
serviceAccountKey.json

# Cloud Functions (server/functions)
server/functions/node_modules/
server/functions/lib/
.firebase/
firebase-debug.log
firestore-debug.log
