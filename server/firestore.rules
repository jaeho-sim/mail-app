rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Per-user app settings (signature, theme, sync interval, favorite
    // mailboxes) — only the signed-in owner can read/write their own doc.
    match /userConfigs/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Maps a connected Gmail address + this device's FCM token, so the
    // gmailPushRelay Cloud Function knows where to deliver a push. Scoped by
    // ownerUid (the app's signed-in identity, set by PushRegistrar.swift) —
    // not by document ID, since the ID is keyed by email+token, not uid.
    // The Cloud Function itself uses the Admin SDK, which bypasses these
    // rules entirely, so this only governs direct client access.
    match /pushSubscriptions/{subscriptionId} {
      allow read, write: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
